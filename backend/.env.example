# Copy to .env and fill in values
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15

# yolov8n-pose.pt = fast, good for dev. Swap to a custom fall-detection .pt later.
YOLO_MODEL=yolov8n-pose.pt
YOLO_CONFIDENCE=0.5
YOLO_DEVICE=cpu

# Require N consecutive alert frames before firing (reduces false positives)
ALERT_CONSECUTIVE_FRAMES=3
ALERT_COOLDOWN_SECONDS=120

# Fall heuristics (tuned for pose model — adjust after testing)
FALL_HORIZONTAL_RATIO=1.4
FALL_LOW_IN_FRAME=0.55

# Butterbase webhook (set when app is created)
BUTTERBASE_WEBHOOK_URL=https://api.butterbase.ai/v1/app_7e7uf91ohmyx/fn/yolo-alert
BUTTERBASE_API_KEY=
SENIOR_ID=senior_001
DEVICE_ID=device_living_room

# Optional: save snapshot on alert
SNAPSHOT_DIR=./data/snapshots
SAVE_SNAPSHOTS=true

# API server (health checks, manual test trigger)
API_HOST=0.0.0.0
API_PORT=8080

# Vapi private key — used by scripts/setup-vapi-assistant.mjs only (never expose to frontend)
VAPI_API_KEY=
# Outbound family calls (from dashboard.vapi.ai → Phone Numbers)
VAPI_PHONE_NUMBER_ID=
VAPI_FAMILY_ASSISTANT_ID=
