# Butterbase (Senior Guardian cloud backend)
VITE_BUTTERBASE_APP_ID=app_7e7uf91ohmyx
VITE_BUTTERBASE_API_URL=https://api.butterbase.ai
# Optional — public access mode works without anon key for dev
VITE_BUTTERBASE_ANON_KEY=

# Vapi (run: node scripts/setup-vapi-assistant.mjs with VAPI_API_KEY set)
# Set these in EdgeOne project env for https://senior-guardian.edgeone.dev
VITE_VAPI_PUBLIC_KEY=
VITE_VAPI_ASSISTANT_ID=

# Optional: public URL of the vision service (only if exposed via tunnel).
# Leave unset on EdgeOne — camera runs on the home tablet at localhost:8080.
# VITE_BACKEND_URL=
# VITE_API_URL=

# Used by scripts/setup-vapi-assistant.mjs (must match Butterbase vapi-tools env)
# VAPI_TOOL_SECRET=sg_vapi_tools_7k9m2x
